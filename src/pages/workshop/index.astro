---
import "../../styles/global.css"
import Layout from "../../layouts/Layout.astro"
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { PencilRuler } from 'lucide-astro';

const posts = (await getCollection('workshop'))
  .filter(post => !post.data.private)
  .sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
---

<Layout>
  <!-- Page Header -->
  <section class="max-w-3xl mb-16 sm:mb-24">
    <div class="flex items-center gap-4 mb-8">
        <PencilRuler class="w-10 h-10 text-neutral-400 dark:text-neutral-500" />
        <h1 class="text-4xl sm:text-5xl font-bold text-neutral-900 dark:text-neutral-100 font-serif tracking-tight">
          The <span class="text-blue-500 dark:text-blue-400 italic decoration-blue-500/75 dark:decoration-blue-400/75 underline underline-offset-8">Workshop</span>
        </h1>
    </div>
    
    <p class="text-lg sm:text-xl text-neutral-800 dark:text-neutral-100 leading-snug text-justify font-serif font-bold">
      "The bench. Where theory meets the reality of making."
    </p>

    <p class="text-base sm:text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed text-justify font-serif mt-4 font-medium">
      A space for project implementations and small-scale experiments. Here I document the process of building, crafting, and exploring across various mediums and interests.
    </p>
  </section>

  <!-- Posts Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 max-w-5xl">
    {posts.map((post) => (
      <article class="group relative bg-white dark:bg-neutral-900 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 shadow-sm hover:shadow-md transition-all duration-300 flex flex-col">
        <a href={`/workshop/${post.id}/`} class="flex flex-col h-full">
          {/* Hero Image */}
          {post.data.heroImage && (
            <div class="aspect-video overflow-hidden border-b-2 border-neutral-100 dark:border-neutral-800">
              <Image
                src={post.data.heroImage} 
                alt={post.data.title}
                width={800}
                height={450}
                class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-500"
                loading="lazy"
              />
            </div>
          )}
          
          <div class="p-5 flex flex-col flex-grow">
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-3 gap-2">
              <h3 class="text-lg font-bold text-neutral-900 dark:text-neutral-100 font-serif tracking-tight group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors leading-tight">
                {post.data.title}
              </h3>
              <span class="text-[10px] font-mono font-bold text-neutral-500 dark:text-neutral-400 uppercase tracking-widest bg-neutral-50 dark:bg-neutral-800 px-2 py-0.5 rounded border border-neutral-200 dark:border-neutral-700 whitespace-nowrap">
                {new Date(post.data.pubDate).toLocaleDateString('en-US', {
                  month: 'short',
                  year: 'numeric'
                })}
              </span>
            </div>

            {post.data.description && (
              <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-6 leading-relaxed font-serif font-medium italic line-clamp-3">
                {post.data.description}
              </p>
            )}

            <div class="mt-auto pt-3 border-t border-neutral-100 dark:border-neutral-800">
              <p class="text-[10px] font-mono font-medium text-neutral-500 dark:text-neutral-500 uppercase tracking-widest leading-relaxed">
                <span class="font-bold mr-2 text-neutral-400 dark:text-neutral-600">Tags: </span>
                <span class="text-neutral-700 dark:text-neutral-300 font-serif normal-case tracking-normal text-sm font-bold">
                    {post.data.tags ? post.data.tags.join(' • ') : 'Project Entry'}
                </span>
              </p>
            </div>
          </div>
        </a>
      </article>
    ))}
  </div>
</Layout>
