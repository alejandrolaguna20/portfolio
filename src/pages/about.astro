---
import "../styles/global.css"
import Layout from "../layouts/Layout.astro"
import NavigationCard from "../components/NavigationCard.astro"
import ExperienceCard from '../components/ExperienceCard.astro';
import { PencilRuler, LibraryBig, ScrollText, Mail, Github, Linkedin, Fingerprint } from 'lucide-astro';

const navItems = [
  {
    href: "/workshop", 
    icon: PencilRuler,
    heading: "Workshop",
    content: "The bench. A space for projects, experiments, and creative implementations across any medium."
  },
  {
    href: "/library",
    icon: LibraryBig, 
    heading: "Library",
    content: "Foundational resources. A curated archive of research."
  },
  {
    href: "/log",
    icon: ScrollText,
    heading: "Log", 
    content: "Chronicles of progress. Documenting the iterative process of learning and growth in all pursuits."
  }
];

---

<Layout>
  <!-- Hero Section -->
<section class="max-w-3xl mb-10 sm:mb-14">
  <h1 class="text-4xl sm:text-5xl font-bold mb-6 text-neutral-900 dark:text-neutral-100 font-serif tracking-tight">About</h1>
  <p class="text-lg sm:text-xl text-neutral-800 dark:text-neutral-100 leading-snug text-justify font-serif font-bold">
      I am a Software Engineer and student at <a class="underline hover:text-blue-600 dark:hover:text-blue-400 transition-colors decoration-2 underline-offset-4" href="https://www.epitech.eu/">Epitech</a> Barcelona.
    </p>

  <p class="text-base sm:text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed text-justify font-serif mt-4 font-medium">
    My current focus is <b>Systems Programming</b>. I architect software that demands performance and a rigorous interface between computational logic and the physical world. This specialization is built upon a professional foundation of shipping production systems and a track record of technical reliability.
  </p>
</section>

  <!-- Experience Section -->
  <section class="mb-12">
    <h2 class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-8 font-serif underline decoration-blue-300/50 dark:decoration-blue-700/50 underline-offset-8 decoration-2 uppercase tracking-tight">
       Experience
    </h2>
    <div class="grid sm:grid-cols-1 gap-6">
      <ExperienceCard 
        title="Software Engineer Intern"
        company="MigaLabs"
        period="July 2025 - Dec 2025"
        location="Barcelona, Spain"
        achievements={[
          "Built monitoring tools for TB-scale Ethereum data; ensured high-fidelity quality control at scale.",
          "Designed cross-fork validation systems and studied Ethereum specs (Phase0 to Capella) for data correctness.",
          "Optimized analytics dashboard using Next.js to visualize complex protocol-level insights."
        ]}
        technologies="Go • Next.js • ClickHouse • Ethereum"
      />
      <ExperienceCard 
        title="Full-Stack Developer"
        company="Avantiam Inc."
        period="Sep 2023 - Aug 2024"
        location="Figueres, Spain"
        achievements={[
          "Architected multitenant management platform serving 100+ companies from a unified codebase.",
          "Engineered real-time HR and task management tools using Laravel and Livewire stack."
        ]}
        technologies="Laravel • PHP • JavaScript • Livewire"
      />
      <ExperienceCard 
        title="Backend Developer Intern" 
        company="Niblu Group"
        period="Summer 2023"
        location="Maribor, Slovenia"
        achievements={[
          "Spent a summer in Slovenia through Erasmus+, working on an e-learning platform while in a foreign country alone at 17",
        ]}
        technologies="FastAPI • NextJS • TypeScript • AWS"
      />
    </div>
  </section>

  <!-- Education Section -->
  <section class="mb-12 bg-white dark:bg-neutral-900 p-6 sm:p-8 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 shadow-sm relative overflow-hidden group">
    <h2 class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-8 font-serif relative z-10 underline decoration-blue-300/50 dark:decoration-blue-700/50 underline-offset-8 decoration-2 uppercase tracking-tight">
       Education
    </h2>
    <div class="relative z-10">
      <ul class="space-y-10 font-serif">
        <li class="relative pl-8 border-l-2 border-blue-500 dark:border-blue-400">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
             <p class="text-lg text-neutral-900 dark:text-neutral-100 font-bold tracking-tight">European Institute of Technology (EPITECH)</p>
             <span class="text-[10px] text-neutral-500 dark:text-neutral-400 font-mono font-bold tracking-widest uppercase bg-neutral-50 dark:bg-neutral-800 px-2 py-0.5 rounded border border-neutral-200 dark:border-neutral-700">2024 - 2029</span>
          </div>
          <p class="text-base text-neutral-700 dark:text-neutral-300 font-semibold leading-tight">Bachelor + Master's Degree in Computer Science</p>
          <div class="flex items-center gap-4 mt-3">
            <p class="text-sm text-neutral-500 dark:text-neutral-400 italic">Barcelona, Spain</p>
          </div>
        </li>

        <li class="relative pl-8 border-l-2 border-neutral-200 dark:border-neutral-800">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-1">
              <p class="text-lg text-neutral-900 dark:text-neutral-100 font-bold tracking-tight">INS Cendrassos</p>
              <span class="text-[10px] text-neutral-500 dark:text-neutral-400 font-mono font-bold tracking-widest uppercase bg-neutral-50 dark:bg-neutral-800 px-2 py-0.5 rounded border border-neutral-200 dark:border-neutral-700">2022 - 2024</span>
          </div>
          <p class="text-base text-neutral-700 dark:text-neutral-300 font-semibold leading-tight">Systems & Networking (Medium Degree)</p>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 italic mt-2 font-bold">Erasmus+ Scholarship • Student of the Year</p>
        </li>
      </ul>
    </div>
  </section>

  <!-- Technical Focus Section -->
  <section class="mb-12 bg-white dark:bg-neutral-900 p-8 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 shadow-sm relative font-serif">
      <h2 class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-8 font-serif underline decoration-blue-300/50 dark:decoration-blue-700/50 underline-offset-8 decoration-2 uppercase tracking-tight">
      Technical Arsenal
    </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <div class="p-6 rounded-lg bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
      <h3 class="text-[12px] font-bold text-blue-500 dark:text-blue-400 uppercase tracking-widest mb-3">Systems & Low-Level</h3>
      <p class="text-lg text-neutral-900 dark:text-neutral-100 font-bold font-mono tracking-tighter mb-2">C • C++ • Go • Rust</p>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
        Focus on manual memory management, hardware-software interfacing, and high-concurrency patterns. 
      </p>
    </div>

    <div class="p-6 rounded-lg bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
      <h3 class="text-[12px] font-bold text-blue-500 dark:text-blue-400 uppercase tracking-widest mb-3">Data Architecture</h3>
      <p class="text-lg text-neutral-900 dark:text-neutral-100 font-bold font-mono tracking-tighter mb-2">ClickHouse • PostgreSQL • SQL</p>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
        Specialized in high-throughput analytical engines and optimizing relational schemas for large-scale data ingestion.
      </p>
    </div>

    <div class="p-6 rounded-lg bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
      <h3 class="text-[12px] font-bold text-blue-500 dark:text-blue-400 uppercase tracking-widest mb-3">Numerical & Functional</h3>
      <p class="text-lg text-neutral-900 dark:text-neutral-100 font-bold font-mono tracking-tighter mb-2">Haskell • Typst</p>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
        Exploring functional paradigms for symbolic logic and typesetting systems for technical documentation.
      </p>
    </div>

    <div class="p-6 rounded-lg bg-white dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800">
      <h3 class="text-[12px] font-bold text-blue-500 dark:text-blue-400 uppercase tracking-widest mb-3">Environment Control</h3>
      <p class="text-lg text-neutral-900 dark:text-neutral-100 font-bold font-mono tracking-tighter mb-2">Arch Linux • Neovim • Bash • GDB</p>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed">
        Minimalist, terminal-centric development environment optimized for deep work and process-level debugging.
      </p>
    </div>
  </div>

  <div class="mt-12 pt-6 border-t border-neutral-100 dark:border-neutral-800">
    <p class="text-[9px] uppercase tracking-widest text-blue-400 dark:text-blue-500 font-bold mb-2 italic">Support Ecosystem & Legacy</p>
    <p class="text-xs font-mono text-neutral-500 dark:text-neutral-400">
      TS/JS • Python • NextJS • Astro • PHP • Laravel • MongoDB
    </p>
  </div>
</section>

  <!-- Beyond the Machine Section -->
<section class="mb-16 bg-neutral-50 dark:bg-neutral-800/40 p-6 sm:p-8 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 shadow-sm relative overflow-hidden group">
    <div class="absolute top-0 right-0 p-6 opacity-5 dark:opacity-[0.03] pointer-events-none transition-transform group-hover:scale-110 duration-700">
        <Fingerprint class="w-32 h-32 text-neutral-900 dark:text-neutral-100" />
    </div>

    <h2 class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-8 font-serif relative z-10 underline decoration-blue-300/50 dark:decoration-blue-700/50 underline-offset-8 decoration-2 uppercase tracking-tight">
        Beyond the Terminal
    </h2>

    <div class="relative z-10 font-serif">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="space-y-3">
          <h3 class="text-base font-bold text-neutral-900 dark:text-neutral-100 mb-2 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-500 dark:bg-blue-400"></span>
              Physical Foundation
          </h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed font-medium">
            Morning pool sessions. High-intensity sprint swimming as a tool for aerobic capacity and mental focus.
          </p>
        </div>

        <div class="space-y-3">
          <h3 class="text-base font-bold text-neutral-900 dark:text-neutral-100 mb-2 flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-blue-500 dark:bg-blue-400"></span>
              Intellectual Curiosity
          </h3>
          <p class="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed font-medium text-pretty">
            I’m fascinated by Astrophysics and Astronomy. Currently exploring the physical constraints of the universe to better understand the constraints of the systems I build.
          </p>
        </div>
      </div>
    </div>
</section>

  <!-- Contact Section -->
  <section class="mb-16">
    <h2 class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-8 font-serif underline decoration-blue-300/50 dark:decoration-blue-700/50 underline-offset-8 decoration-2 uppercase tracking-tight">
      Contact
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div class="space-y-6 font-sans">
        <a href="mailto:alejandro.laguna@epitech.eu" class="group block transition-all">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-white dark:bg-neutral-900 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 group-hover:border-blue-500 dark:group-hover:border-blue-400 transition-all shadow-sm">
              <Mail class="w-6 h-6 text-neutral-400 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-0.5 font-mono">Email</p>
              <p class="text-lg font-black text-neutral-900 dark:text-neutral-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors font-serif">alejandro.laguna@epitech.eu</p>
            </div>
          </div>
        </a>
        <a href="https://github.com/alejandrolaguna20" target="_blank" class="group block transition-all">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-white dark:bg-neutral-900 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 group-hover:border-blue-500 dark:group-hover:border-blue-400 transition-all shadow-sm">
              <Github class="w-6 h-6 text-neutral-400 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-0.5 font-mono">GitHub</p>
              <p class="text-lg font-black text-neutral-900 dark:text-neutral-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors font-serif">github.com/alejandrolaguna20</p>
            </div>
          </div>
        </a>
        <a href="https://linkedin.com/in/alejandro-laguna" target="_blank" class="group block transition-all">
          <div class="flex items-center gap-4">
            <div class="p-3 bg-white dark:bg-neutral-900 rounded-xl border-2 border-neutral-200 dark:border-neutral-800 group-hover:border-blue-500 dark:group-hover:border-blue-400 transition-all shadow-sm">
              <Linkedin class="w-6 h-6 text-neutral-400 group-hover:text-blue-500 dark:group-hover:text-blue-400 transition-colors" />
            </div>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-neutral-400 mb-0.5 font-mono">LinkedIn</p>
              <p class="text-lg font-black text-neutral-900 dark:text-neutral-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors font-serif">linkedin.com/in/alejandro-laguna</p>
            </div>
          </div>
        </a>
      </div>
<div class="p-10 border-2 border-dashed border-neutral-200 dark:border-neutral-800 rounded-xl bg-neutral-50/50 dark:bg-neutral-900/10 flex flex-col items-center justify-center text-center font-serif group">
    <p class="text-xl sm:text-2xl text-neutral-800 dark:text-neutral-200 font-bold leading-tight tracking-tight max-w-xl">
        "I'm hungry to learn how code can eventually help us understand the stars."
    </p>
</div>
    </div>
  </section>

  <!-- Navigation -->
  <section class="mb-20 sm:mb-28 mt-20" aria-labelledby="navigation-heading">
    <h2 class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-10 font-serif underline decoration-blue-300/50 dark:decoration-blue-700/50 underline-offset-8 decoration-2 uppercase tracking-tight">
      Navigation
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-1 lg:grid-cols-3 gap-6">
      {navItems.map(item => (
        <NavigationCard
          href={item.href}
          icon={item.icon}
          heading={item.heading}
          content={item.content}
        />
      ))}
    </div>
  </section>
</Layout>
