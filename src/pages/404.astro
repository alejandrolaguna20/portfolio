---
import "../styles/global.css"
import Layout from "../layouts/Layout.astro"
import NavigationCard from '../components/NavigationCard.astro';
import { ArrowLeft } from 'lucide-astro';

const navItems = [
  {
    href: "/",
    icon: ArrowLeft,
    heading: "Home",
    content: "Return to the main directory."
  },
];
---
<Layout>
  <section class="max-w-3xl mb-16 sm:mb-24">
    <h1 class="text-4xl sm:text-5xl font-bold mb-8 text-neutral-900 dark:text-neutral-100 font-serif tracking-tight">
      Error <span class="text-neutral-500 dark:text-neutral-500 italic decoration-neutral-300 dark:decoration-neutral-700 underline underline-offset-8">404</span>
    </h1>
    
    <p class="text-lg sm:text-xl text-neutral-800 dark:text-neutral-100 leading-snug text-justify font-serif font-bold">
      The requested resource could not be located. This path may have been deprecated, moved, or never existed in the current implementation.
    </p>

    <p class="text-base sm:text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed text-justify font-serif mt-4 font-medium">
      I strive for persistent URI reliability, but system migrations sometimes lead to broken links. If you believe this is a technical error, please report it. Otherwise, you may return to the entry point.
    </p>
  </section>

  <section class="mb-20 sm:mb-28" aria-labelledby="navigation-heading">
    <h2 id="navigation-heading" class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-10 font-serif underline decoration-neutral-300 dark:decoration-neutral-700 underline-offset-8 decoration-2 uppercase tracking-tight">
      Navigation
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6">
      {navItems.map(item => (
        <NavigationCard
          href={item.href}
          icon={item.icon}
          heading={item.heading}
          content={item.content}
        />
      ))}
    </div>
  </section>
</Layout>