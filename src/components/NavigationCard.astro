---
export interface Props {
  href: string;
  icon: any;
  heading: string;
  content: string;
}

const { href, icon: Icon, heading, content } = Astro.props;
---

<a 
  href={href} 
  class="nav-card group block p-8 rounded-xl bg-white dark:bg-neutral-900 border-2 border-neutral-200 dark:border-neutral-800 shadow-sm hover:border-blue-300 dark:hover:border-blue-600 transition-all duration-300 relative overflow-hidden"
>
  <div class="flex flex-col gap-5 relative z-10">
    <Icon class="w-8 h-8 text-neutral-400 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors duration-300" />
    <div>
      <h3 class="text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-3 font-serif underline decoration-neutral-200 dark:decoration-neutral-800 underline-offset-4 group-hover:decoration-blue-400 transition-colors">{heading}</h3>
      <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-serif font-medium">{content}</p>
    </div>
  </div>
</a>
