---
import "../styles/global.css"
import Layout from "../layouts/Layout.astro"
import NavigationCard from '../components/NavigationCard.astro';
import { ArrowLeft, Construction, Fingerprint } from 'lucide-astro';

const navItems = [
  {
    href: "/",
    icon: ArrowLeft,
    heading: "Home",
    content: "Return to the main directory."
  },
  {
    href: "/about",
    icon: Fingerprint,
    heading: "About",
    content: "Learn more about the architect and the principles driving this work."
  }
];
---

<Layout>
  <section class="max-w-3xl mb-16 sm:mb-24">
    <div class="flex items-center gap-4 mb-8">
        <Construction class="w-10 h-10 text-neutral-400 dark:text-neutral-500" />
        <h1 class="text-4xl sm:text-5xl font-bold text-neutral-900 dark:text-neutral-100 font-serif tracking-tight">
          Module <span class="text-neutral-500 dark:text-neutral-500 italic decoration-neutral-300 dark:decoration-neutral-700 underline underline-offset-8">Pending</span>
        </h1>
    </div>
    
    <p class="text-lg sm:text-xl text-neutral-800 dark:text-neutral-100 leading-snug text-justify font-serif font-bold">
      This section is currently under active development. I am architecting the underlying systems to ensure technical rigor and content fidelity.
    </p>

    <p class="text-base sm:text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed text-justify font-serif mt-4 font-medium">
      Implementation of this module is prioritized but not yet finalized for production. I believe in shipping only when the quality of documentation matches the quality of the engineering it describes. Check back as the system evolves.
    </p>
  </section>

  <section class="mb-20 sm:mb-28" aria-labelledby="navigation-heading">
    <h2 id="navigation-heading" class="flex items-center gap-2 text-xl font-bold text-neutral-900 dark:text-neutral-100 mb-10 font-serif underline decoration-neutral-300 dark:decoration-neutral-700 underline-offset-8 decoration-2 uppercase tracking-tight">
      Navigation
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6">
      {navItems.map(item => (
        <NavigationCard
          href={item.href}
          icon={item.icon}
          heading={item.heading}
          content={item.content}
        />
      ))}
    </div>
  </section>
</Layout>